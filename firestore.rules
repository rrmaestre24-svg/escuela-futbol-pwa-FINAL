rules_version = '2';
// ============================================================
// REGLAS DE SEGURIDAD FIRESTORE — MyClub
//
// Principio: cada usuario autenticado solo puede leer y
// escribir los datos del club al que pertenece.
//
// Hay tres tipos de acceso:
//   1. Admin      → autenticado con email/password, doc en clubs/{clubId}/users/{uid}
//   2. Entrenador → auth anónima + código verificado → sesión en authorized_sessions
//   3. Padre      → auth anónima + código verificado → sesión en authorized_sessions
//
// Para desplegar: firebase deploy --only firestore:rules
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funciones helper ────────────────────────────────────

    // Admin del club: tiene documento en clubs/{clubId}/users/{uid}
    function isMemberOfClub(clubId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/clubs/$(clubId)/users/$(request.auth.uid));
    }

    // Super administrador global
    function isSuperAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/super_admins/$(request.auth.uid));
    }

    // Entrenador o padre que completó el login con código y tiene sesión activa en ESTE club.
    // Esto evita que un usuario de Club A acceda a los datos de Club B.
    function isSessionForClub(clubId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/clubs/$(clubId)/authorized_sessions/$(request.auth.uid));
    }

    // Padre autenticado para ESTE jugador específico.
    // La sesión del padre guarda { role: 'parent', playerId }.
    function isParentSessionForPlayer(clubId, playerId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/clubs/$(clubId)/authorized_sessions/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/clubs/$(clubId)/authorized_sessions/$(request.auth.uid)).data.role == 'parent' &&
        get(/databases/$(database)/documents/clubs/$(clubId)/authorized_sessions/$(request.auth.uid)).data.playerId == playerId;
    }

    // ── Datos generales del club ────────────────────────────
    // Regla comodín: el admin y super admin acceden a todo.
    // Las subcolecciones sensibles tienen reglas más específicas abajo.
    match /clubs/{clubId}/{document=**} {
      allow read, write: if isMemberOfClub(clubId) || isSuperAdmin();
    }

    // ── Sesiones autorizadas (entrenadores y padres) ────────
    // Cada usuario anónimo puede crear y actualizar su propia sesión.
    // El update es necesario cuando el mismo usuario vuelve a hacer login
    // (el doc ya existe, entonces .set() es un update, no un create).
    // El admin puede borrarlas para revocar acceso manualmente.
    match /clubs/{clubId}/authorized_sessions/{uid} {
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow read:           if request.auth != null && request.auth.uid == uid;
      allow delete:         if isMemberOfClub(clubId) || isSuperAdmin();
    }

    // ── Entrenadores ────────────────────────────────────────
    // Lectura abierta a cualquier autenticado: necesaria para verificar el código
    // ANTES de que exista la sesión (es el primer paso del login).
    // Create/delete: solo el admin.
    // Update: cualquier autenticado — necesario para auto-revocar acceso expirado.
    match /clubs/{clubId}/coaches/{document} {
      allow read:          if request.auth != null;
      allow create, delete: if isMemberOfClub(clubId) || isSuperAdmin();
      allow update:        if isMemberOfClub(clubId) || isSuperAdmin() || isSessionForClub(clubId);
    }

    // ── Asistencia ──────────────────────────────────────────
    // El entrenador necesita guardar y leer registros de asistencia.
    // Requiere sesión activa en el club específico.
    match /clubs/{clubId}/attendance/{document} {
      allow read, write: if isMemberOfClub(clubId) || isSuperAdmin() || isSessionForClub(clubId);
    }

    // ── Notificaciones al entrenador ────────────────────────
    match /clubs/{clubId}/coach_notifications/{document} {
      allow read, write: if isMemberOfClub(clubId) || isSuperAdmin() || isSessionForClub(clubId);
    }

    // ── Alertas de morosos ──────────────────────────────────
    match /clubs/{clubId}/moroso_alerts/{document} {
      allow read, write: if isMemberOfClub(clubId) || isSuperAdmin() || isSessionForClub(clubId);
    }

    // ── Documento raíz del club ─────────────────────────────
    // Necesario para mostrar el nombre del club en la app del entrenador/padre.
    match /clubs/{clubId} {
      allow read: if request.auth != null;
    }

    // ── Códigos de acceso de padres ─────────────────────────
    // Lectura abierta a cualquier autenticado: necesaria para verificar el código
    // ANTES de que exista la sesión (primer paso del login del padre).
    match /clubs/{clubId}/parentCodes/{document} {
      allow read: if request.auth != null;
    }

    // ── Jugadores ───────────────────────────────────────────
    // Lectura:
    // - Admin y super admin: acceso completo.
    // - Padres: solo su jugador asociado en sesión.
    // - Entrenadores (y sesiones legacy no-parent): lectura del club.
    // Escritura parcial: los padres pueden actualizar solo campos de perfil personal.
    match /clubs/{clubId}/players/{playerId} {
      allow read: if isMemberOfClub(clubId)
        || isSuperAdmin()
        || isParentSessionForPlayer(clubId, playerId)
        || (isSessionForClub(clubId)
          && get(/databases/$(database)/documents/clubs/$(clubId)/authorized_sessions/$(request.auth.uid)).data.role != 'parent');
      allow update: if isMemberOfClub(clubId) || isSuperAdmin() ||
        (isParentSessionForPlayer(clubId, playerId) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'birthDate', 'medicalInfo', 'avatar', 'updatedAt', 'updatedBy', 'documents']));
    }

    // ── Configuración del club ──────────────────────────────
    // Los entrenadores y padres necesitan leer el nombre y moneda del club.
    match /clubs/{clubId}/settings/{document} {
      allow read: if isMemberOfClub(clubId) || isSuperAdmin() || isSessionForClub(clubId);
    }

    // ── Pagos ───────────────────────────────────────────────
    // Solo el admin puede leer y escribir pagos.
    // Los padres con sesión activa solo pueden leer pagos de SU jugador asociado.
    // Los entrenadores NO tienen acceso a pagos.
    match /clubs/{clubId}/payments/{document} {
      allow read: if isMemberOfClub(clubId)
        || isSuperAdmin()
        || isParentSessionForPlayer(clubId, resource.data.playerId);
      allow write: if isMemberOfClub(clubId) || isSuperAdmin();
    }

    // ── Eventos ─────────────────────────────────────────────
    // Los entrenadores y padres pueden ver los próximos eventos.
    match /clubs/{clubId}/events/{document} {
      allow read: if isMemberOfClub(clubId) || isSuperAdmin() || isSessionForClub(clubId);
    }

    // ── Excepción: registro inicial del admin ───────────────
    // Cuando un admin crea su club por primera vez, todavía no tiene
    // documento en users/ — le permitimos crear solo su propio documento.
    match /clubs/{clubId}/users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId
        && !exists(/databases/$(database)/documents/clubs/$(clubId)/settings/main);
    }

    // ── Mapeo email → clubId ────────────────────────────────
    match /userClubMapping/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == email;
    }

    // ── Códigos de activación ───────────────────────────────
    match /activation_codes/{code} {
      allow read:  if true; // Público para verificar antes del registro
      allow update: if request.auth != null 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedBy', 'usedAt'])
        && resource.data.used == false; // Solo permite mascar como usado si no lo estaba
      allow create, delete: if isSuperAdmin();
    }

    // ── Sugerencias ─────────────────────────────────────────
    match /suggestions/{docId} {
      allow read: if request.auth != null;

      // Crear sugerencias: cualquier autenticado, pero sin permitir
      // respuestas pre-cargadas ni estados finales al crear.
      allow create: if request.auth != null
        && request.resource.data.status == 'pending'
        && (!('response' in request.resource.data) || request.resource.data.response == null)
        && (!('responseAt' in request.resource.data) || request.resource.data.responseAt == null)
        && (!('respondedBy' in request.resource.data) || request.resource.data.respondedBy == null)
        && (!('responseRead' in request.resource.data) || request.resource.data.responseRead == false);

      // Actualizar sugerencias:
      // - Super Admin: respuesta completa, cambio de estado, etc.
      // - Usuarios autenticados: solo marcar como leída.
      allow update: if isSuperAdmin()
        || (request.auth != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responseRead'])
          && request.resource.data.responseRead == true
          && (!('senderUid' in resource.data) || resource.data.senderUid == request.auth.uid));

      // Eliminar sugerencias: solo super admin.
      allow delete: if isSuperAdmin();
    }

    // ── Licencias (colección raíz) ──────────────────────────
    match /licenses/{clubId} {
      allow read:  if request.auth != null;
      allow create: if request.auth != null && !exists(/databases/$(database)/documents/licenses/$(clubId));
      allow update, delete: if isSuperAdmin();
    }

    // ── Facturación (Super Admin) ───────────────────────────
    match /billing/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // ── Super Admin ─────────────────────────────────────────
    match /super_admins/{uid} {
      allow read:  if isSuperAdmin();
      allow write: if isSuperAdmin() && request.auth.uid == uid;
    }

    // ── Licencias (ruta alternativa bajo superadmin) ────────
    match /superadmin/{document=**} {
      allow read:  if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // ── Bloquear todo lo demás ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
