rules_version = '2';
// ============================================================
// REGLAS DE SEGURIDAD FIRESTORE — MyClub
//
// Principio: cada usuario autenticado solo puede leer y
// escribir los datos del club al que pertenece.
// Verificamos que exista su documento en clubs/{clubId}/users/{uid}.
//
// Para desplegar: firebase deploy --only firestore:rules
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funciones helper ────────────────────────────────────
    // Devuelve true si el usuario autenticado tiene un documento
    // en la subcolección users del club que quiere acceder.
    function isMemberOfClub(clubId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/clubs/$(clubId)/users/$(request.auth.uid));
    }

    // Devuelve true si el usuario autenticado es super admin.
    // El super admin tiene un documento en la colección super_admins con su UID.
    function isSuperAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/super_admins/$(request.auth.uid));
    }

    // ── Datos del club ──────────────────────────────────────
    // jugadores, pagos, eventos, egresos, configuración, etc.
    // El super admin también puede leer y escribir cualquier club.
    match /clubs/{clubId}/{document=**} {
      allow read, write: if isMemberOfClub(clubId) || isSuperAdmin();
    }

    // ── Entrenadores: acceso con auth anónima + club ID + código ──
    // Los entrenadores se autentican de forma anónima. Necesitan leer
    // su propio perfil de coach para verificar el código, y también
    // escribir asistencias y leer jugadores/eventos.
    match /clubs/{clubId}/coaches/{document} {
      // Leer: para verificar el código al hacer login
      // Actualizar: para revocar acceso expirado automáticamente
      allow read, update: if request.auth != null;
    }
    match /clubs/{clubId}/attendance/{document} {
      // Los entrenadores guardan y leen los registros de asistencia
      allow read, write: if request.auth != null;
    }
    match /clubs/{clubId}/coach_notifications/{document} {
      // Notificaciones que el admin envía al entrenador
      allow read, write: if request.auth != null;
    }
    match /clubs/{clubId}/moroso_alerts/{document} {
      // Alertas de morosos — el entrenador las genera con auth anónima
      allow read, write: if request.auth != null;
    }
    // Documento raíz del club: para mostrar el nombre del club en la app
    match /clubs/{clubId} {
      allow read: if request.auth != null;
    }

    // ── Portal de Padres: acceso con autenticación anónima ──
    // Los padres se autentican de forma anónima y solo pueden
    // leer datos del club para ver el perfil del hijo.
    // Para jugadores, también pueden actualizar solo los campos
    // permitidos: nombre, fecha de nacimiento e info médica.
    match /clubs/{clubId}/parentCodes/{document} {
      allow read: if request.auth != null;
    }
    match /clubs/{clubId}/players/{playerId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['name', 'birthDate', 'medicalInfo', 'avatar', 'updatedAt', 'updatedBy']);
    }
    match /clubs/{clubId}/settings/{document} {
      allow read: if request.auth != null;
    }
    match /clubs/{clubId}/payments/{document} {
      allow read: if request.auth != null;
    }
    match /clubs/{clubId}/events/{document} {
      allow read: if request.auth != null;
    }

    // ── Excepción: registro inicial del admin ───────────────
    // Cuando un admin crea su club por primera vez, todavía no tiene
    // documento en users/ — le permitimos crear solo su propio documento.
    match /clubs/{clubId}/users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // ── Mapeo email → clubId ────────────────────────────────
    // Cada usuario solo puede leer su propio mapeo.
    // El super admin puede leer y escribir cualquier mapeo (para registrar nuevos clubes).
    match /userClubMapping/{email} {
      allow read: if request.auth != null && (request.auth.token.email == email || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    // ── Códigos de activación ───────────────────────────────
    // Lectura: cualquier usuario autenticado (para validar el código).
    // Escritura: necesaria para marcar el código como usado al activarlo.
    match /activation_codes/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Sugerencias ─────────────────────────────────────────
    // Cualquier usuario autenticado puede leer y escribir
    // sus propias sugerencias (admin y portal de padres).
    match /suggestions/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Licencias (colección raíz) ──────────────────────────
    // El sistema guarda y lee licencias en licenses/{clubId}.
    // Cualquier usuario autenticado puede leer/escribir su licencia.
    match /licenses/{clubId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Facturación (Super Admin) ───────────────────────────
    // Solo el super admin puede ver y gestionar las facturas.
    match /billing/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // ── Super Admin: datos de cuentas de administrador ──────
    // El super admin lee y escribe su propio documento (uid).
    // Lectura abierta a cualquier autenticado para la verificación de login.
    match /super_admins/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Licencias (ruta alternativa bajo superadmin) ────────
    // Solo el super admin puede escribir licencias y módulos.
    match /superadmin/{document=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // ── Bloquear todo lo demás ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
